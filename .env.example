# Example environment for the discovery tools under tools/ (e.g. airseekers_cloud_probe.py).
# Copy to .env and fill in YOUR OWN values. .env is gitignored — NEVER commit real credentials.
#
# These are NOT used by the Home Assistant integration itself (HA stores config in its config entry).
# They exist only so the owner can probe THEIR OWN cloud account during protocol discovery.
#
# The base URL is intentionally blank: the real AIRSEEKERS API is UNVERIFIED. Do not invent it —
# fill it in only after you have observed it from your own app/account traffic.

AIRSEEKERS_BASE_URL=
AIRSEEKERS_USERNAME=
AIRSEEKERS_PASSWORD=

# Optional: a robot IP discovered on your LAN (used by local probes).
AIRSEEKERS_HOST=
